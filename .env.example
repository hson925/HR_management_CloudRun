# Copy to .env and fill in your own values.
# Never commit a real .env.

FLASK_SECRET_KEY=change-me-to-a-long-random-string
OPENAI_API_KEY=sk-...

# Firebase Admin SDK service account (paste the JSON as a single-line string)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account", ...}

# Google Sheets / Drive API service account (paste the JSON as a single-line string)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account", ...}

# Google OAuth — internal staff login
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Google OAuth — external evaluators (separate client)
EXTERNAL_CLIENT_ID=your-external-client-id.apps.googleusercontent.com
EXTERNAL_CLIENT_SECRET=your-external-client-secret

# Scheduler bypass header for cron-style endpoints
NT_SYNC_SECRET=any-long-random-string
